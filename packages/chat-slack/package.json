{
  "name": "@viberglass/chat-slack",
  "version": "1.0.0",
  "description": "Slack chat extension for Viberator platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "@viberglass/types": "*",
    "chat": "^4.22.0"
  },
  "devDependencies": {
    "@viberglass/types": "*",
    "chat": "^4.22.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
