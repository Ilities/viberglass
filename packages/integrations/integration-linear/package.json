{
  "name": "@viberglass/integration-linear",
  "version": "1.0.0",
  "description": "Linear integration for Viberglass platform",
  "main": "./dist/backend/index.js",
  "module": "./dist/backend/index.mjs",
  "types": "./dist/backend/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.mjs",
      "require": "./dist/backend/index.js"
    },
    "./frontend": {
      "types": "./dist/frontend/index.d.mts",
      "import": "./dist/frontend/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@viberglass/integration-core": "*",
    "@viberglass/platform-ui": "*",
    "@viberglass/types": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
