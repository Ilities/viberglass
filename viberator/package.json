{
  "name": "vibug-viberator",
  "version": "1.0.0",
  "type": "module",
  "description": "AI Agent Orchestrator for bug fixing with multiple AI coding CLIs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "start:api": "node dist/api-server.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "tsup --watch --onSuccess \"node dist/api-server.js\"",
    "dev:worker": "tsup --watch --onSuccess \"node dist/bullmq-worker.js\"",
    "dev:lambda-worker": "tsup --watch --onSuccess \"node dist/lambda-handler.js\"",
    "test": "jest",
    "docker:build": "docker build -t vibug-viberator .",
    "docker:run": "docker run --env-file .env vibug-viberator",
    "compose:up": "docker-compose up",
    "compose:down": "docker-compose down"
  },
  "keywords": [
    "ai",
    "bug-fixing",
    "orchestrator",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "aws-lambda": "^1.0.7",
    "@anthropic-ai/claude-code": "^2.0.75",
    "@aws-sdk/client-ssm": "^3.0.0",
    "axios": "^1.6.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "simple-git": "^3.30.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "tsup": "^8.0.0",
    "prettier": "^3.7.4",
    "typescript": "^5.0.0"
  }
}
