# Backend Development Container
# This container runs the backend API with hot-reload support via nodemon
# NOTE: Build from repository root for workspace dependencies: docker build -f platform/backend/Dockerfile.dev .

FROM node:20-alpine

WORKDIR /app

# Copy monorepo root package.json for workspace resolution
COPY package*.json ./

# Create backend directory and copy its package.json
RUN mkdir -p platform/backend
COPY platform/backend/package*.json ./platform/backend/

# Install all dependencies (workspace-aware from root)
RUN npm install --legacy-peer-deps

# Copy all workspace packages (types, backend source, etc.)
COPY packages/types ./packages/types
COPY platform/backend ./platform/backend

# Expose backend API port
EXPOSE 8888

# Set working directory to backend for running the server
WORKDIR /app/platform/backend

# Use nodemon for hot-reload (matches "npm run dev" script)
CMD ["npm", "run", "dev"]
