# Production stack configuration
# Copy this file to Pulumi.prod.yaml and update with your values
# Usage: pulumi stack select prod

encryptionsalt:
  - v1:YOUR_SALT_HERE

config:
  # AWS region for all resources
  aws:region: eu-west-1
  viberglass:awsRegion: eu-west-1

  # Environment name (dev, staging, prod)
  # Affects resource naming, log retention, and cost optimizations
  viberglass:environment: prod

  # Base stack reference (REQUIRED)
  # Format: organization/<project>/<stack> for S3 backends
  viberglass:baseStack: organization/viberglass-base/prod

  # Enable Fargate Spot for cost savings (70% discount)
  # Disabled for production to ensure consistent performance
  viberglass:enableSpot: "false"

  # Enable ECS Container Insights for enhanced monitoring
  # Adds CloudWatch metrics for CPU/memory, network, storage
  viberglass:containerInsights: "true"

  # Database configuration (optional - defaults shown)
  # Valid instance classes: db.m6g.xlarge, db.m6g.2xlarge, etc.
  # viberglass:dbInstanceClass: db.m6g.xlarge
  # viberglass:dbAllocatedStorage: 100
