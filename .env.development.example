# Viberator Development Environment Template
# Copy this file to .env.local and customize with your actual values
# The docker-compose.yml uses default values that work for local development

# --------------------------
# Database Configuration
# --------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=viberator
DB_USER=viberator
DB_PASSWORD=viberator_dev

# --------------------------
# Redis Configuration
# --------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --------------------------
# Backend Configuration
# --------------------------
PORT=8888
NODE_ENV=development
LOG_LEVEL=debug

# --------------------------
# Frontend Configuration
# --------------------------
NEXT_PUBLIC_API_URL=http://localhost:8888

# --------------------------
# Worker Configuration
# --------------------------
# Platform API URL for workers running in containers
# Note: host.docker.internal works on Docker Desktop (Mac/Windows)
# and on Linux with extra_hosts: "host.docker.internal:host-gateway"
PLATFORM_API_URL=http://host.docker.internal:8888

# --------------------------
# External Services (Optional)
# --------------------------
# GitHub PAT for posting PR comments (used by workers)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API Key for Claude (used by workers)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --------------------------
# AWS Configuration (Optional)
# --------------------------
# Only needed if running with LocalStack for E2E tests
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:4566
