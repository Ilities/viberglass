{
  "name": "@viberglass/e2e-aws-tests",
  "version": "1.0.0",
  "description": "AWS end-to-end tests for Viberglass platform",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:specific": "playwright test --grep",
    "provision-test-data": "ts-node scripts/provision-test-data.ts",
    "cleanup-test-data": "ts-node scripts/provision-test-data.ts cleanup",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.654.0",
    "@aws-sdk/client-ecs": "^3.654.0",
    "@aws-sdk/client-s3": "^3.654.0",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
