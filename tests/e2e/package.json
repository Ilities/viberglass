{
  "name": "@viberator/e2e-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "setup:docker": "docker compose -f docker/docker-compose.e2e.yaml up -d",
    "teardown:docker": "docker compose -f docker/docker-compose.e2e.yaml down -v",
    "setup:services": "tsx playwright/setupServices.ts",
    "teardown:services": "tsx playwright/teardownServices.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@testcontainers/localstack": "^10.0.0",
    "dockerode": "^4.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.10.0",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
