# Application Configuration
MODE=server
PORT=3000
LOG_LEVEL=info
LOG_FORMAT=json

# Git Configuration (for commits)
GIT_USER_NAME=Vibes Viber
GIT_USER_EMAIL=viberator@viberglass.io

# Execution Settings
MAX_CONCURRENT_JOBS=3
DEFAULT_TIMEOUT=2700
RETRY_ATTEMPTS=2

# AWS Configuration (optional)
AWS_REGION=us-west-2
SSM_PARAMETER_PATH=/viberglass

# Agent API Keys
# Claude Code supports official env vars (priority order):
#   CLAUDE_CODE_API_KEY > ANTHROPIC_API_KEY > ANTHROPIC_AUTH_TOKEN
#   CLAUDE_CODE_ENDPOINT > ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=your_claude_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: custom API endpoint
QWEN_CLI_API_KEY=your_qwen_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
CODEX_API_KEY=your_openai_api_key_here
MISTRAL_VIBE_API_KEY=your_mistral_api_key_here
GEMINI_CLI_API_KEY=your_gemini_api_key_here

# Agent Endpoints (optional - use custom endpoints)
# CLAUDE_CODE_ENDPOINT=https://api.anthropic.com/v1
# QWEN_CLI_ENDPOINT=https://api.qwen.ai/v1
# QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/codemodify/text-completion
# CODEX_ENDPOINT=https://api.openai.com/v1
# MISTRAL_VIBE_ENDPOINT=https://api.mistral.ai/v1
# GEMINI_CLI_ENDPOINT=https://generativelanguage.googleapis.com/v1

# CLI Mode Configuration (when MODE=cli)
REPO_URL=https://github.com/example/repo.git
BRANCH=main
BUG_DESCRIPTION=Sample bug that needs to be fixed
STEPS_TO_REPRODUCE=1. Step one 2. Step two 3. Bug occurs
EXPECTED_BEHAVIOR=The application should work correctly
ACTUAL_BEHAVIOR=The application crashes or behaves incorrectly
BUG_SEVERITY=medium
LANGUAGE=javascript
TESTING_REQUIRED=true