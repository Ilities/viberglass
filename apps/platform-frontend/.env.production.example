# Production environment variables for AWS Amplify deployment
# Copy this file to .env.production.local for local testing
# In Amplify Console, set these as environment variables in the app settings

# Backend API URL - The API endpoint for the backend service
# For AWS deployments, use the ALB URL or API Gateway URL
# Example: https://api-abc123.eu-west-1.elb.amazonaws.com
# Example with custom domain: https://api.viberator.com
NEXT_PUBLIC_API_URL=

# Frontend CDN URL - Optional, for absolute asset references
# Amplify provides this automatically via NEXT_PUBLIC_URL
# Only set if you need to reference assets from a different CDN
# Example: https://d111111abcdef8.cloudfront.net
NEXT_PUBLIC_CDN_URL=

# Amplify-specific environment variables (automatically set):
# - AWS_AMPLIFY_BRANCH: Git branch name
# - AWS_AMPLIFY_DEPLOYMENT_TYPE: deployment type
# - NEXT_PUBLIC_URL: Full URL of the deployed Amplify app

# Notes for Amplify Console setup:
# 1. In Amplify Console, navigate to App Settings > Environment Variables
# 2. Add NEXT_PUBLIC_API_URL with your backend API endpoint
# 3. Amplify automatically sets AWS_ and NEXT_PUBLIC_URL variables
# 4. Variables prefixed with NEXT_PUBLIC_ are embedded in the client bundle
