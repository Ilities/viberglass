# Frontend Development Container
# This container runs the Vite + React frontend with HMR (Hot Module Reload)
# NOTE: Build from repository root for workspace dependencies: docker build -f apps/platform-frontend/Dockerfile.dev .

FROM node:24-alpine

WORKDIR /app

# Copy monorepo root package.json for workspace resolution
COPY package*.json ./

# Create workspace directories and copy their package.json files
RUN mkdir -p apps/platform-frontend packages/types packages/integration-core packages/platform-ui
COPY apps/platform-frontend/package*.json ./apps/platform-frontend/
COPY packages/types/package*.json ./packages/types/
COPY packages/integration-core/package*.json ./packages/integration-core/
COPY packages/platform-ui/package*.json ./packages/platform-ui/

# Integration plugins use a glob workspace; copy full source for package.json resolution
COPY packages/integrations ./packages/integrations

# Install all dependencies (workspace-aware from root)
RUN npm install --legacy-peer-deps

# Copy all workspace packages (types, frontend source, etc.)
# Note: In docker-compose, source is mounted via volume, overriding these copies
COPY packages/types ./packages/types
COPY packages/integration-core ./packages/integration-core
COPY packages/platform-ui ./packages/platform-ui
COPY apps/platform-frontend ./apps/platform-frontend

# Build shared packages (needed before frontend can start)
RUN npm run build -w @viberglass/types && npm run build -w @viberglass/integration-core && npm run build -w @viberglass/platform-ui && npm run build --workspaces --if-present -w @viberglass/integration-bitbucket -w @viberglass/integration-custom -w @viberglass/integration-github -w @viberglass/integration-gitlab -w @viberglass/integration-jira -w @viberglass/integration-linear -w @viberglass/integration-monday -w @viberglass/integration-shortcut -w @viberglass/integration-slack

# Expose Vite default port
EXPOSE 3000

# Set working directory to frontend for running the dev server
WORKDIR /app/apps/platform-frontend

# Image-built dist/ is used directly — no runtime build needed
CMD ["npm", "run", "dev"]
