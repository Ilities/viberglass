# Frontend Development Container
# This container runs the Vite + React frontend with HMR (Hot Module Reload)
# NOTE: Build from repository root for workspace dependencies: docker build -f apps/platform-frontend/Dockerfile.dev .

FROM node:24-alpine

WORKDIR /app

# Copy monorepo root package.json for workspace resolution
COPY package*.json ./

# Create workspace directories and copy their package.json files
RUN mkdir -p apps/platform-frontend packages/types
COPY apps/platform-frontend/package*.json ./apps/platform-frontend/
COPY packages/types/package*.json ./packages/types/

# Install all dependencies (workspace-aware from root)
RUN npm install --legacy-peer-deps

# Copy all workspace packages (types, frontend source, etc.)
# Note: In docker-compose, source is mounted via volume, overriding these copies
COPY packages/types ./packages/types
COPY apps/platform-frontend ./apps/platform-frontend

# Build shared types package (needed before frontend can start)
RUN npm run build -w @viberglass/types

# Expose Vite default port
EXPOSE 3000

# Set working directory to frontend for running the dev server
WORKDIR /app/apps/platform-frontend

# Image-built dist/ is used directly — no runtime build needed
CMD ["npm", "run", "dev"]
