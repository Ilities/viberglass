PORT=4000
SLACK_APP_BASE_URL=https://your-public-url
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_STATE_SECRET=your-state-secret
SLACK_SCOPES=chat:write,commands,app_mentions:read,channels:read,groups:read,im:read,mpim:read
SLACK_INSTALLATION_STORE_PATH=./data/slack-installations.json
SLACK_LOG_LEVEL=info
